# ═══════════════════════════════════════════════════════
# PaperTradeX — Environment Variables
# ═══════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════

# ─── JWT Configuration ──────────────────────────────
# Base64-encoded secret key for JWT token signing (min 32 bytes)
JWT_SECRET=cGFwZXJ0cmFkZXgtand0LXNlY3JldC1rZXktMzJieXRlcy1sb25n

# Token expiration in milliseconds (default: 24 hours)
JWT_EXPIRATION_MS=86400000

# ─── Database (Optional — defaults to H2 in-memory) ─
# Uncomment and set for MySQL:
# SPRING_PROFILES_ACTIVE=mysql
# SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/papertradex
# SPRING_DATASOURCE_USERNAME=root
# SPRING_DATASOURCE_PASSWORD=root

# ─── Server ─────────────────────────────────────────
# SERVER_PORT=8080
